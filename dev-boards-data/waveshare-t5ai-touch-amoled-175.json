{
  "schemaVersion": 1,
  "peripheralPatterns": {
    "audio": [
      {
        "name": {
          "en": "Audio",
          "zh-CN": "音频"
        },
        "interface": "INTERNAL",
        "mounting": "onboard",
        "pinLocked": true,
        "pins": {
          "INTERNAL": [
            {
              "role": "pa_ctrl",
              "gpio": 28,
              "activeLevel": "high"
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "AEC enabled. 2 audio ADCs (mic), 1 DAC. Speaker via MX1.25 connector (8Ω 1W/2W). pa_ctrl active low. MIC1 = microphone input, MIC2 = AEC reference, LP/LN = differential speaker output.",
          "zh-CN": "已启用 AEC。2 路音频 ADC（麦克风），1 路 DAC。扬声器通过 MX1.25 接口（8Ω 1W/2W）。pa_ctrl 低有效。MIC1 = 麦克风输入，MIC2 = AEC 回采，LP/LN = 差分喇叭输出。"
        },
        "id": "audio"
      }
    ],
    "display": [
      {
        "model": "CO5300",
        "name": {
          "en": "1.75-inch AMOLED Display",
          "zh-CN": "1.75 寸 AMOLED 屏"
        },
        "interface": "QSPI",
        "pins": {
          "QSPI": [
            {
              "role": "sck",
              "gpio": 22
            },
            {
              "role": "cs",
              "gpio": 23
            },
            {
              "role": "sio0",
              "gpio": 24
            },
            {
              "role": "sio1",
              "gpio": 25
            },
            {
              "role": "sio2",
              "gpio": 26
            },
            {
              "role": "sio3",
              "gpio": 27
            },
            {
              "role": "rst",
              "gpio": 29
            },
            {
              "role": "te",
              "gpio": 31
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "QSPI Port 0, 80 MHz. 16.7M colors, RGB565. LVGL supported with dual display buffer. Backlight controlled via CO5300 command.",
          "zh-CN": "QSPI 端口 0，80 MHz。1670 万色，RGB565。支持 LVGL 双显示缓冲。背光通过 CO5300 命令控制。"
        },
        "mounting": "onboard",
        "pinLocked": true,
        "id": "display",
        "width": 466,
        "height": 466
      }
    ],
    "touchpad": [
      {
        "model": "CST9217",
        "name": {
          "en": "Capacitive Touch",
          "zh-CN": "电容触控"
        },
        "interface": "I2C",
        "pins": {
          "I2C": [
            {
              "role": "scl",
              "gpio": 20
            },
            {
              "role": "sda",
              "gpio": 21
            },
            {
              "role": "int",
              "gpio": 42
            },
            {
              "role": "rst",
              "gpio": 43
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "I2C0. Tempered glass with self-capacitance design. Mirror X/Y enabled.",
          "zh-CN": "I2C0。钢化玻璃自电容设计。X/Y 轴镜像已启用。"
        },
        "mounting": "onboard",
        "pinLocked": true,
        "id": "touchpad"
      }
    ],
    "sd_card": [
      {
        "model": null,
        "name": {
          "en": "Micro SD Card",
          "zh-CN": "Micro SD 卡"
        },
        "interface": "SDIO",
        "pins": {
          "SDIO": [
            {
              "role": "clk",
              "gpio": 2
            },
            {
              "role": "cmd",
              "gpio": 3
            },
            {
              "role": "d0",
              "gpio": 4
            },
            {
              "role": "d1",
              "gpio": 5
            },
            {
              "role": "d2",
              "gpio": 10
            },
            {
              "role": "d3",
              "gpio": 11
            },
            {
              "role": "cd",
              "gpio": 8
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "4-bit SDIO. Card detect on GPIO 8.",
          "zh-CN": "4 位 SDIO。卡检测引脚 GPIO 8。"
        },
        "mounting": "onboard",
        "pinLocked": true,
        "id": "sd-card"
      }
    ],
    "led": [
      {
        "model": null,
        "name": {
          "en": "Indicator LED",
          "zh-CN": "指示灯"
        },
        "interface": "GPIO",
        "pins": {
          "GPIO": [
            {
              "role": "led",
              "gpio": 47
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "Active high. Also exposed on breakout header.",
          "zh-CN": "高有效。同时引出至排针。"
        },
        "mounting": "onboard",
        "pinLocked": true,
        "id": "led"
      }
    ],
    "button": [
      {
        "name": {
          "en": "User Button",
          "zh-CN": "用户按键"
        },
        "interface": "GPIO",
        "mounting": "onboard",
        "pinLocked": true,
        "pins": {
          "GPIO": [
            {
              "role": "btn",
              "gpio": 12
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "Active low with pull-up. Separate reset button also present.",
          "zh-CN": "低有效带上拉。另有独立复位按键。"
        },
        "id": "button"
      }
    ],
    "power": [
      {
        "model": null,
        "name": {
          "en": "Power Management",
          "zh-CN": "电源管理"
        },
        "interface": "GPIO",
        "pins": {
          "GPIO": [
            {
              "role": "sys_en",
              "gpio": 19
            },
            {
              "role": "sys_out",
              "gpio": 18
            },
            {
              "role": "bat_adc",
              "gpio": 13
            },
            {
              "role": "bat_chg",
              "gpio": 30
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "sys_en: power latch, active high — hold high after boot. sys_out: power button detect, active low. bat_adc: battery voltage ADC. bat_chg: charge status.",
          "zh-CN": "sys_en：电源锁存，高有效——启动后须保持高电平。sys_out：电源按键检测，低有效。bat_adc：电池电压 ADC。bat_chg：充电状态。"
        },
        "mounting": "onboard",
        "pinLocked": true,
        "id": "power"
      }
    ]
  },
