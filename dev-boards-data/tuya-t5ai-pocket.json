        "mounting": "onboard",
        "pinLocked": true,
        "port": 0,
        "model": "ST7305",
        "width": 168,
        "height": 384,
        "pixelFormat": "MONOCHROME",
        "backlight": "GPIO",
        "blPwmChannel": 0,
        "timing": {
          "syncMode": "VH",
          "clkEdge": "rising"
