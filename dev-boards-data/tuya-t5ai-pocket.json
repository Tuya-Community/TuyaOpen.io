        "kconfig": null,
        "note": {
          "en": "Mono. SPI0 pinmux group 2 — MISO(47) repurposed as DC. LVGL supported.",
          "zh-CN": "单色屏。SPI0 引脚复用组 2，MISO(47) 复用为 DC。支持 LVGL。"
        }
      }
    ],
