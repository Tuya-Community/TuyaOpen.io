        "kconfig": null,
        "note": {
          "en": "AEC enabled. mux_sel: low = mic to MIC2, high = speaker loopback.",
          "zh-CN": "AEC 已启用。mux_sel：低电平接麦克风，高电平接扬声器回环。"
        },
        "id": "audio"
      }
    ],
    "display": [
      {
