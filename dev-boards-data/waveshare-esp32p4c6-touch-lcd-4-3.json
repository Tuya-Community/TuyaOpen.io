{
  "schemaVersion": 1,
  "peripheralPatterns": {
    "display": [
      {
        "id": "display",
        "name": {
          "en": "4.3-inch IPS LCD",
          "zh-CN": "4.3 寸 IPS 显示屏"
        },
        "model": "ST7701",
        "interface": "RGB",
        "width": 480,
        "height": 800,
        "pixelFormat": "RGB565",
        "mounting": "onboard",
        "pinLocked": true,
        "pins": {
          "RGB": [
            {
              "role": "rst",
              "gpio": 27
            },
            {
              "role": "bl",
              "gpio": 26,
              "activeLevel": "high"
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "MIPI-DSI 2-lane panel (ST7701, JD9365-compatible) driven over the DSI PHY — the high-speed data/clock lanes are dedicated DSI pins, not GPIO-mappable, so only rst (GPIO27) and backlight bl (GPIO26, LEDC PWM, active high) are listed. Video timing: 480x800, DPI clock 30 MHz, lane bitrate 500 Mbps.",
          "zh-CN": "MIPI-DSI 2-lane 面板（ST7701，兼容 JD9365），经 DSI PHY 驱动——高速数据/时钟差分对为专用 DSI 引脚，不可映射到 GPIO，故仅列出 rst（GPIO27）与背光 bl（GPIO26，LEDC PWM，高有效）。视频时序：480x800，DPI 时钟 30 MHz，lane 速率 500 Mbps。"
        }
      }
    ],
    "touchpad": [
      {
        "id": "touchpad",
        "name": {
          "en": "Capacitive Touch",
          "zh-CN": "电容触控"
        },
        "model": "GT911",
        "interface": "I2C",
        "mounting": "onboard",
        "pinLocked": true,
        "pins": {
          "I2C": [
            {
              "role": "scl",
              "gpio": 8
            },
            {
              "role": "sda",
              "gpio": 7
            },
            {
              "role": "rst",
              "gpio": 23
            }
          ]
        },
        "kconfig": null,
        "group": "i2c-bus-1",
        "note": {
          "en": "GT911 capacitive touch on shared I2C1 (scl=8, sda=7) at address 0x5D (or 0x14). INT is not connected (NC).",
          "zh-CN": "GT911 电容触摸，挂在共享 I2C1（scl=8，sda=7），地址 0x5D（或 0x14）。INT 未连接（NC）。"
        }
      }
    ],
    "audio": [
      {
        "id": "audio",
        "name": {
          "en": "ES8311 Audio Codec",
          "zh-CN": "ES8311 音频编解码器"
        },
        "model": "ES8311",
        "interface": "I2S",
        "mounting": "onboard",
        "pinLocked": true,
        "pins": {
          "I2S": [
            {
              "role": "mclk",
              "gpio": 13
            },
            {
              "role": "bck",
              "gpio": 12
            },
            {
              "role": "ws",
              "gpio": 10
            },
            {
              "role": "dout",
              "gpio": 9
            },
            {
              "role": "din",
              "gpio": 11
            },
            {
              "role": "spk_en",
              "gpio": 53
            }
          ],
          "I2C": [
            {
              "role": "scl",
              "gpio": 8
            },
            {
              "role": "sda",
              "gpio": 7
            }
          ]
        },
        "kconfig": null,
        "group": "i2c-bus-1",
        "note": {
          "en": "ES8311 codec on I2S1; I2C control bus shared on I2C1 (scl=8, sda=7) at address 0x30. spk_en (power amp enable) = GPIO53. Board also carries an ES7210 ADC for dual-MEMS-mic capture.",
          "zh-CN": "ES8311 编解码器，I2S1；I2C 控制总线共享 I2C1（scl=8，sda=7），地址 0x30。spk_en（功放使能）= GPIO53。板上另有 ES7210 ADC 用于双 MEMS 麦克风采集。"
        }
      }
    ],
    "button": [
      {
        "id": "button",
        "name": {
          "en": "User Button",
          "zh-CN": "用户按键"
        },
        "count": 1,
        "interface": "GPIO",
        "mounting": "onboard",
        "pinLocked": true,
        "pins": {
          "GPIO": [
            {
              "role": "btn",
              "gpio": 0,
              "activeLevel": "low"
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "On-board BOOT button (GPIO0), active low with pull-up.",
          "zh-CN": "板载 BOOT 按键（GPIO0），低有效带上拉。"
        }
      }
    ]
  },
  "peripheralGroups": {
    "i2c-bus-1": {
      "name": {
        "en": "Shared I2C1 Bus",
        "zh-CN": "共享 I2C1 总线"
      },
      "note": {
        "en": "I2C1 (scl=GPIO8, sda=GPIO7) is shared by the GT911 touch and the ES8311 audio codec (0x30).",
        "zh-CN": "I2C1（scl=GPIO8，sda=GPIO7）由 GT911 触摸与 ES8311 音频编解码器（0x30）共用。"
      }
    }
  },
